# ============================================================
# Project Zenith — backend environment variables
# Copy this file to backend/.env and fill in values as needed.
# ============================================================

# HTTP server port
# Default: 4000
PORT=4000

# Allowed CORS origin for the frontend
# Default: http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Gemini API key (optional — required for live AI narration)
# Without this key the narrator returns a deterministic fallback response.
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model name (optional)
# Default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# OpenWeather API key (optional — required for live observing conditions)
# Without this key the conditions card shows a degraded/unavailable state.
# Free tier: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ChromaDB URL (optional — required for semantic narrator retrieval)
# Without this key the narrator uses an in-memory lexical fallback corpus.
# Run Chroma locally: docker run -p 8000:8000 chromadb/chroma
CHROMA_URL=http://localhost:8000

# Chroma Cloud API key (optional)
# If set, backend uses Chroma Cloud token auth instead of the local client.
CHROMA_API_KEY=

# Chroma Cloud tenant/database (optional unless your key needs explicit routing)
CHROMA_TENANT=
CHROMA_DATABASE=

# ChromaDB collection name (optional)
# Default: zenith-knowledge
CHROMA_COLLECTION=zenith-knowledge

# Maximum number of TLE satellite records to load (optional)
# Lower values reduce memory use; higher values improve satellite coverage.
# Default: 6000
SATELLITE_LIMIT=6000

# Force demo mode at the backend level (optional)
# When true, /api/* endpoints always return demo data even without ?demo=1.
# Useful for staging environments. Prefer per-request demo mode in dev.
# Default: false
ZENITH_DEMO_MODE=false
