# ============================================================
# Project Zenith — frontend environment variables
# Copy this file to .env.local and fill in values as needed.
# ============================================================

# URL of the Zenith backend API (required for live mode)
# Default: http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Cesium ion access token (optional)
# Required only if you use Cesium ion-hosted terrain or imagery.
# Free tier: https://ion.cesium.com/tokens
# Without this token the globe still loads using the bundled offline assets.
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Demo mode (optional)
# Set to "1" to enable offline demo data on startup, without relying on
# live API responses. You can also activate demo mode at runtime by
# appending ?demo=1 to any URL, or by calling enableDemo() in the browser
# console and reloading.
# Default: (empty = live mode)
NEXT_PUBLIC_DEMO_MODE=
